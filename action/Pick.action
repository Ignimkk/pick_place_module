# ============================================================
# Pick.action
#
# 그리퍼 열기 → pre-grasp 이동(RRT) → grasp 직선 접근(Cartesian)
# → 그리퍼 닫기 → 직선 후퇴(Cartesian) 까지 수행
# ============================================================

# --- Goal ---
geometry_msgs/Pose pick_pose   # 그리핑 목표 포즈 (world frame)

---

# --- Result ---
bool   success
string message

---

# --- Feedback ---
string  status     # 현재 실행 단계 설명
float32 progress   # 0.0 ~ 1.0 진행률
